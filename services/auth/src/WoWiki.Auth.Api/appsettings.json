{
  "ConnectionStrings": {
    "AuthDatabase": "Data Source=Data/wowiki-auth.db;Cache=Shared;Foreign Keys=True"
  },
  "Auth": {
    "CookieName": "wowiki.auth",
    "SessionDays": 7
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "localhost"
}
